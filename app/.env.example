# Environment Variables for OkHabit
# Copy to .env.local and fill in values. .env.local is gitignored.

# ─── Local Supabase (run `supabase start` from project root first) ───
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Cloud Supabase (uncomment and replace when using hosted project) ───
# Get from: https://app.supabase.com/project/_/settings/api
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
