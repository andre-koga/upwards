# Supabase CLI environment variables (optional)
# Copy to .env in project root if needed. Used by config.toml for env(VAR) substitution.
#
# No vars required for basic local development.
# Add these only when enabling OAuth or other providers in config.toml:
#
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# etc.
